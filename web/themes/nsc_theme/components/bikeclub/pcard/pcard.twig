{#  pcard.twig is "included" in bikeclub_solo/templates/paragraphs/paragraph--card.html.twig
    which must be modified if fields are added.
 #}

{% set bg_color = shaded ? 'bg-secondary': '#ffffff' %}
{% set height = full_height ? 'h-100': 'h-auto' %}

<div class= "table clear-both m-2 mb-4 pt-4 px-4 w-auto rounded-2xl shadow-md {{ bg_color }} {{ height }}">
  <div class="w-full p-0">
    {% if image %}
      {% if link %}
        <a href="{{ link }}"> {{ image }} </a>  
      {% else %}
        {{ image }}
      {% endif %}
    {% endif %}
  </div>

  <div>
    {% if link %}
      <a href="{{ link }}">
        <h3><center>{{ title }}</center></h3>
      </a>
    {% else %}
      <h3><center>{{ title }}</center></h3>
    {% endif %}  

    {{ content }}
  </div>
</div>